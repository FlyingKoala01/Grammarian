{
  "name": "grammarian",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter @grammarian/shared build && pnpm -r --parallel --filter @grammarian/api --filter @grammarian/web dev",
    "dev:db:down": "docker compose -f docker-compose.dev.yml down",
    "dev:db:logs": "docker compose -f docker-compose.dev.yml logs -f db",
    "dev:db:reset": "docker compose -f docker-compose.dev.yml down -v",
    "dev:db:up": "docker compose -f docker-compose.dev.yml up -d db",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm --filter @grammarian/shared build && pnpm -r --if-present typecheck"
  }
}
